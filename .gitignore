.DS_Store

# Per-deployment files (operator supplies these; never committed)
/assets/js/source/kyte-connect.js
/assets/js/source/kyte-source.js
/assets/js/kyte-dev.js

# Build artifacts — minified output of esbuild, regenerated by `npm run build`.
# Source lives in /assets/js/source/ and is tracked; the top-level
# /assets/js/*.js files are emitted by the build pipeline and shipped to S3
# from CI rather than from git.
/assets/js/*.js
/assets/js/*.js.map

# Node toolchain (esbuild build pipeline)
node_modules/
